<% title_html = capture do %>
  <%= icon 'magnifying-glass', class: 'w-5 h-5 text-gray-400' %>
  <%= form_with url: search_modal_path,
                method: :get,
                class: 'flex-1 flex',
                data: { turbo_frame: :search_results, 'game-search-target': 'form' } do |f| %>
    <%= f.search_field :query,
                       type: :text,
                       placeholder: 'Search games by title...',
                       autocomplete: 'off',
                       data: { action: 'input->game-search#search' },
                       class: 'flex-1 bg-transparent outline-none text-lg placeholder-gray-500' %>
  <% end %>
<% end %>

<%= render 'shared/modal', title: title_html, stretch_mobile: true, wrapper_controller: 'game-search' do %>
  <%= turbo_frame_tag(:search_results, class: 'grow flex flex-col') do %>
  <div id="searchResults" class="sm:max-h-96 overflow-y-auto grow flex flex-col">
    <% if @games.blank? %>
      <!-- Empty state -->
      <div id="emptyState" class="py-12 text-center justify-center text-gray-500 grow flex flex-col">
        <%= icon 'magnifying-glass', class: 'w-12 h-12 mx-auto mb-3 text-gray-600' %>
        <p>Начните вводить название игры...</p>
      </div>
    <% else %>
      <div class="px-0 py-0 flex flex-col gap-1">
        <% @games.each do |game| %>
          <%= render 'games/shared/search_result_game', game: game %>
        <% end %>
      </div>
    <% end %>
  </div>
  <% end %>
<% end %>
