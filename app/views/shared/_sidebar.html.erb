<div id="sidebar">
  <% if current_user.present? %>
    <aside data-sb-target="sidebar"
           id="sidebar_container"
           class="fixed left-0 top-16 bottom-0 w-64 bg-gray-800 z-30
                  -translate-x-full lg:translate-x-0 transition duration-300 ease-in-out">
      <nav class="p-4 space-y-2">
        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-gray-700 text-white">
          <%= icon 'home', class: 'w-5 h-5' %>
          <span>Home</span>
        </a>

        <!-- Events -->
        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400
                         hover:bg-gray-700 hover:text-white">
          <%= icon 'calendar', class: 'w-5 h-5' %>
          <span>My Events</span>
          <span class="ml-auto bg-purple-600 text-white text-xs rounded-full px-2 py-1">3</span>
        </a>

        <!-- Friends -->
        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg
                         text-gray-400 hover:bg-gray-700 hover:text-white">
          <%= icon 'users', class: 'w-5 h-5' %>
          <span>Friends</span>
        </a>

        <!-- Divider -->
        <div class="border-t border-gray-700 my-4"></div>

        <!-- Create Event Button -->
        <button class="w-full flex items-center justify-center gap-2 px-4 py-3 rounded-lg
                     bg-purple-600 hover:bg-purple-700 text-white font-medium">
            <%= icon 'plus', class: 'w-5 h-5' %>
            <span>Create Event</span>
        </button>
      </nav>
    </aside>
  <% end %>
</div>
