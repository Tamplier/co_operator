<%# locals: (search_url:) %>

<% title_html = capture do %>
  <%= icon 'magnifying-glass', class: 'w-5 h-5 text-gray-400' %>
  <%= form_with url: search_url,
                method: :get,
                class: 'flex-1 flex',
                data: { turbo_frame: :search_results, 'game-search-target': 'form' } do |f| %>
    <%= f.search_field :query,
                       value: params[:query],
                       type: :text,
                       placeholder: t('.search_placeholder'),
                       autocomplete: 'off',
                       data: { action: 'input->game-search#search' },
                       class: 'flex-1 bg-transparent outline-none text-lg placeholder-gray-500' %>
  <% end %>
<% end %>

<%= render 'shared/modal', title: title_html, stretch_mobile: true, wrapper_controller: 'game-search' do %>
  <div data-game-search-target="spinner"
       data-game-search-wrapper-classes-value='["rounded-b-xl", "z-20"]'></div>
  <div class="sm:max-h-96 overflow-y-auto flex-1 min-h-0 grow flex flex-col scrollbar -mx-2 px-2">
    <%= yield %>
  </div>
<% end %>
