<a href="#" id="sidebar_events"
            class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400
                 hover:bg-gray-700 hover:text-white">
  <%= icon 'calendar', class: 'w-5 h-5' %>
  <span><%= t '.my_events' %></span>
  <% if current_profile.social_events.exists? %>
    <span class="ml-auto bg-purple-600 text-white text-xs rounded-full px-2 py-1">
      <%= current_profile.social_events.count %>
    </span>
  <% end %>
</a>
