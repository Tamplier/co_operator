<%# locals: (pagination:) %>

<%
  button_style = 'px-3 py-1 bg-gray-900 rounded-lg text-gray-300 border border-gray-900 '\
                 'hover:border-gray-600 hover:bg-gray-700'
%>

<% if pagination.total_pages > 1 %>
  <div class="flex items-center justify-center gap-3 mt-4">
    <%= link_to url_for(request.query_parameters.merge(page: pagination.prev_page)),
                class: class_names(button_style, invisible: pagination.prev_page.blank?) do %>
      &lt;
    <% end %>
    <%= pagination.page %>
    <%= link_to url_for(request.query_parameters.merge(page: pagination.next_page)),
                class: class_names(button_style, invisible: pagination.next_page.blank?) do %>
      &gt;
    <% end %>
  </div>
<% end %>
