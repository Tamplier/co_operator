<%
  input_class = 'text_input sm:w-2/3'
  data = { controller: 'submit', turbo_frame: '_top' }
  url = session_path(resource_name)
  notification = resource.instance_variable_get(:@form_notice)
%>

<%= render 'shared/modal', title: 'Log in' do %>
  <%= simple_form_for(resource, as: resource_name, url: url, data: data) do |f| %>

    <div class="flex flex-col justify-center items-center gap-4">
      <%= f.error_notification message: f.object.errors[:base].to_sentence, class: 'alert alert-alert' %>
      <% if notification.present? %>
        <div class="alert alert-notice">
          <%= resource.instance_variable_get(:@form_notice) %>
        </div>
      <% end %>
      <%= f.email_field :email,
                        autocomplete: 'email',
                        placeholder: 'Email',
                        error: true,
                        class: input_class,
                        required: true %>
      <%= f.password_field :password,
                           autocomplete: 'current-password',
                           placeholder: 'Password',
                           error: true,
                           class: input_class,
                           required: true %>
      <% if devise_mapping.recoverable? %>
        <div class="w-full sm:w-2/3 flex justify-end">
          <%= link_to 'Forgot your password?',
                      new_password_path(resource_name),
                      class: 'text-sm text-gray-400 hover:text-purple-400 transition -mt-3' %>
        </div>
      <% end %>

      <% if devise_mapping.rememberable? %>
        <div class="w-full sm:w-2/3 flex gap-4 justify-between">
          <%= f.input :remember_me, as: :toggle, label: 'Remember me', size: :md %>
          <%= f.button :button,
                       'Log in',
                       class: 'cta',
                       type: :submit %>
        </div>
      <% end %>
    </div>
  <% end %>
  <div class="mt-6 text-center text-sm text-gray-400">
    Don’t have an account?
    <%= link_to 'Sign up',
                new_registration_path(resource_name),
                class: 'text-purple-400 hover:text-purple-300 font-medium' %>
  </div>
<% end %>
