<%
  url = password_path(resource_name)
  data = { controller: 'submit', turbo_frame: '_top' }
%>

<%= render 'shared/modal', title: 'Forgot your password?' do %>
  <%= simple_form_for(resource, as: resource_name, url: url, html: { method: :post }, data: data) do |f| %>
    <div class="flex flex-col justify-center items-center gap-4">
      <%= f.input :email,
                  label: false,
                  required: true,
                  placeholder: 'Email',
                  autofocus: true,
                  wrapper_html: { class: 'text_input_wrapper' },
                  input_html: { autocomplete: 'email', class: 'text_input' } %>

      <div class="w-full sm:w-2/3 flex justify-end">
        <%= f.button :button, 'Reset password', type: :submit %>
      </div>
    </div>
  <% end %>

  <div class="mt-4 text-center text-sm text-gray-400 flex gap-8 justify-center">
    <%= link_to 'Sign up',
                new_registration_path(resource_name),
                class: 'text-purple-400 hover:text-purple-300 font-medium' %>
    |
    <%= link_to 'Log in',
                user_session_path,
                class: 'text-purple-400 hover:text-purple-300 font-medium' %>
  </div>
<% end %>
