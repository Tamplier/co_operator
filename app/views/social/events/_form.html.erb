<%# locals: (event_form:, profile_presenter:) %>

<%= simple_form_for(event_form, class: 'space-y-5', data: { controller: 'submit' }) do |f| %>
  <div class="flex flex-col gap-2 mb-4">
    <%= dropdown_with_search(
          f.object, :game_id, nil, profile_presenter.games_for_select(:search_dropdown),
          f: f,
          scontroller_values: { path_value: find_game_path },
          label_html: { class: 'inline-block mb-2' }
        ) %>
    <%= f.input :start_date,
                as: :string,
                required: true,
                label_html: { class: 'inline-block mb-2' },
                input_html: { class: 'text_input', type: 'datetime-local' } %>
    <div class="grid grid-cols-2 gap-2">
      <%= f.input :duration_hours,
                  as: :integer,
                  required: true,
                  error: f.object.errors[:duration_hours].first,
                  label_html: { class: 'inline-block mb-2' },
                  input_html: { class: 'text_input', min: 0 } %>
      <%= f.input :duration_minutes,
                  as: :integer,
                  required: true,
                  error: f.object.errors[:duration_minutes].first,
                  label_html: { class: 'inline-block mb-2' },
                  input_html: { class: 'text_input', min: 0 } %>
    </div>
    <div class="grid grid-cols-2 gap-2">
      <%= dropdown_with_search(
            f.object, :language_id, nil, language_options,
            f: f,
            label_html: { class: 'inline-block mb-2' }) %>
      <%= f.input :max_players,
                  as: :integer,
                  required: true,
                  label_html: { class: 'inline-block mb-2' },
                  input_html: { class: 'text_input', min: 2, max: 20 } %>
    </div>
  </div>

  <div class="flex justify-end gap-3 pt-2">
    <%= f.button :button, t('helpers.submit.social_event.create'), type: :submit, class: 'cta' %>
  </div>

<% end %>
