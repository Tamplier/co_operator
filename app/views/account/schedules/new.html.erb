<%= render 'shared/modal', title: t('account.profiles.schedules_info.title'), classes: 'max-w-sm' do %>
  <%= simple_form_for([:account, :profile, :my, @schedule], data: { controller: 'submit toggle' }) do |f| %>
      <div class="flex flex-col gap-2 mb-4">
        <%= f.input :start_time,
                    required: true,
                    as: :string,
                    label_html: { class: 'inline-block mb-2' },
                    input_html: { type: 'time', class: 'text_input' } %>
        <div class="grid grid-cols-2 gap-4">
          <%= f.input :duration_hours,
                      as: :integer,
                      required: true,
                      error: f.object.errors[:duration_hours].first,
                      label_html: { class: 'inline-block mb-2' },
                      input_html: { class: 'text_input', min: 0 } %>
          <%= f.input :duration_minutes,
                      as: :integer,
                      required: true,
                      error: f.object.errors[:duration_minutes].first,
                      label_html: { class: 'inline-block mb-2' },
                      input_html: { class: 'text_input', min: 0 } %>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <%= f.input :recurring,
                    as: :toggle,
                    input_html: { data: { action: 'change->toggle#toggle' } } %>
        <%= f.input :active,
                    as: :toggle %>
      </div>
      <div class="mt-2">
        <div class="<%= class_names(hidden: f.object.recurring) %>" data-toggle-target="item">
          <%= f.input :reference_date,
                      as: :string,
                      label_html: { class: 'inline-block mb-2' },
                      input_html: { type: 'date', class: 'text_input' } %>
        </div>
        <div class="<%= class_names('flex gap-2', hidden: !f.object.recurring) %>" data-toggle-target="item">
        <%= f.collection_check_boxes :days, week_days, :last, :first, item_wrapper_class: 'flex-1' do |b| %>
          <div class="day_selector">
            <%= b.check_box class: 'day_input peer' %>
            <%= b.label class: 'day_label' %>
          </div>
        <% end %>
        </div>
      </div>
      <div class="w-full flex justify-end gap-4 items-center mt-4">
        <%= f.button :button, 'Save', type: :submit, class: 'cta px-10' %>
      </div>
  <% end %>
<% end %>
